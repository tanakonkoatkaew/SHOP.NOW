# Copy ไฟล์นี้เป็น .env แล้วกรอกค่าจริง

# ─── Core ────────────────────────────────────────────────────────────────────
FLASK_SECRET_KEY=your-secret-key-here
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/
MONGO_DB_NAME=ultimate_market_db

# ─── Stripe (ระบบชำระเงินหลัก) ───────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_CURRENCY=thb

# ─── OAuth Login ─────────────────────────────────────────────────────────────
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://127.0.0.1:8080/api/auth/discord/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://127.0.0.1:8080/api/auth/google/callback
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_REDIRECT_URI=http://127.0.0.1:8080/api/auth/facebook/callback

# ─── Google Gemini (AI Chat Assistant) ───────────────────────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
# โมเดลเล็กสำหรับกรองคำถามนอกเรื่อง — ตั้ง off ถ้า key ไม่มีโควต้ารุ่น lite
GEMINI_FILTER_MODEL=off

# ─── SMTP (ส่งคีย์สินค้า + ใบเสร็จทางอีเมล) ──────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_SENDER=

# ─── Security / server behaviour ─────────────────────────────────────────────
# ALLOWED_ORIGINS: comma-separated CORS allowlist. Leave empty in production
# (SPA is served same-origin). Add http://localhost:5173 only for Vite dev server.
ALLOWED_ORIGINS=
FLASK_DEBUG=1
MAX_UPLOAD_MB=5

# ─── Legacy slip-verify (ไม่ได้ใช้ในโฟลว์หลักแล้ว — ชำระผ่าน Stripe) ─────────
# MOCK_OCR=false
# SLIP_AUTO_VERIFY=false
# SLIPOK_API_KEY=
# SLIPOK_BRANCH_ID=
