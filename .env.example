# Copy ไฟล์นี้เป็น .env แล้วกรอกค่าจริง
FLASK_SECRET_KEY=your-secret-key-here
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/
MONGO_DB_NAME=ultimate_market_db
TRUEMONEY_PHONE=
PROMPTPAY_ID=
MOCK_OCR=false
# SLIP_AUTO_VERIFY=true  -> ตรวจสลิปอัตโนมัติ (SlipOK/Vision)
# SLIP_AUTO_VERIFY=false -> ทุกสลิปเข้าคิวให้แอดมินอนุมัติเอง (ฟรี ปลอดภัย)
SLIP_AUTO_VERIFY=false
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://127.0.0.1:8080/api/auth/discord/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://127.0.0.1:8080/api/auth/google/callback
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_REDIRECT_URI=http://127.0.0.1:8080/api/auth/facebook/callback

# SMTP Email Configuration (สำหรับจัดส่งคีย์สินค้าไปยัง Gmail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_SENDER=

# SlipOK API Configuration (สำหรับตรวจสอบสลิปอัตโนมัติ)
SLIPOK_API_KEY=
SLIPOK_BRANCH_ID=


# Google Gemini (AI Chat Assistant)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
GEMINI_FILTER_MODEL=gemini-3.1-flash-lite

# Security / server behaviour
# ALLOWED_ORIGINS: comma-separated CORS allowlist. Leave empty in production
# (SPA is served same-origin). Add http://localhost:5173 only for Vite dev server.
ALLOWED_ORIGINS=
FLASK_DEBUG=1
MAX_UPLOAD_MB=5
